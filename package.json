{
  "name": "sublime-explorer",
  "version": "0.1.0",
  "productName": "Sublime Explorer",
  "description": "File explorer for macOS with tree + content view, like Windows Explorer",
  "author": "malaiac",
  "license": "MIT",
  "main": "main.js",
  "bin": {
    "sublime-explorer": "./bin/sublime-explorer.js"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "build": {
    "appId": "com.malaiac.sublime-explorer",
    "productName": "Sublime Explorer",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "target": ["dmg", "zip"]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "icon.png",
      "node_modules/marked/**/*"
    ],
    "dmg": {
      "title": "Sublime Explorer"
    }
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "marked": "^17.0.5"
  }
}
